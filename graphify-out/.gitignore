# Local-only graphify artifacts — do NOT commit (per graphify team-setup guidance).
# Tracked & shared: graph.json, graph.html, GRAPH_REPORT.md, .graphify_labels.json
manifest.json      # mtime-based; breaks after `git clone`, rebuilt locally
cost.json          # local extraction cost ledger
cache/             # per-machine AST cache; rebuilt for free by `graphify update .`
.graphify_root     # absolute machine path, e.g. C:\exp\my-app
